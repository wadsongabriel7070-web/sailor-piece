local function UpdateSkillsList()
	local all = {}
	local bp = GetBackpack()
	if bp then
		for _, t in pairs(bp:GetChildren()) do
			if t:IsA("Tool") then table.insert(all, t.Name) end
		end
	end
	if Player.Character then
		for _, t in pairs(Player.Character:GetChildren()) do
			if t:IsA("Tool") then
				local found = false
				for _, n in ipairs(all) do if n == t.Name then found = true; break end end
				if not found then table.insert(all, t.Name) end
			end
		end
	end
	for i, name in ipairs(all) do
		if not _SKILL_BUTTONS[name] then CreateSkillButton(name, i) end
	end
	task.wait(0.1)
	SkillsScroll.CanvasSize = UDim2.new(0, 0, 0, SkillsLayout.AbsoluteContentSize.Y + 10)
end

local function HookBackpackEvents(bp)
	if not bp then return end
	bp.ChildAdded:Connect(function(child)
		if child:IsA("Tool") then
			if not _SKILL_BUTTONS[child.Name] then task.wait(0.05); UpdateSkillsList() end
			if _EQUIPPED_SKILLS[child.Name] then task.wait(0.1); EquipTool(child.Name) end
		end
	end)
end

HookBackpackEvents(GetBackpack())

