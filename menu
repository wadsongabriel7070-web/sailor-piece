-- FIX PRINCIPAL: escuta cada tool chegar na backpack
-- Quando uma tool ativa chega, equipa imediatamente
-- =====================================================
local function HookBackpackEvents(backpack)
	if not backpack then return end
	backpack.ChildAdded:Connect(function(child)
		if child:IsA("Tool") then
			-- Criar botão se não existir
			if not _SKILL_BUTTONS[child.Name] then
				task.wait(0.05)
				UpdateSkillsList()
			end
			-- Se esta tool estava ativa, equipa ela assim que chegou na backpack
			if _EQUIPPED_SKILLS[child.Name] then
				task.wait(0.1)
				EquipTool(child.Name)
			end
		end
	end)
end

