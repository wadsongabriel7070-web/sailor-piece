local function SwitchToPage(page)
	_CURRENT_PAGE = page
	if page == "AutoFarm" then
		AutoFarmPage.Visible = true;  SkillsPage.Visible = false
		AutoFarmStroke.Color = C.AC;  AutoFarmIcon.TextColor3 = C.AC;  AutoFarmLabel.TextColor3 = C.AC
		SkillsStroke.Color   = C.BR;  SkillsIcon.TextColor3   = C.TS;  SkillsLabel.TextColor3   = C.TS
	else
		AutoFarmPage.Visible = false; SkillsPage.Visible = true
		UpdateSkillsList()
		AutoFarmStroke.Color = C.BR;  AutoFarmIcon.TextColor3 = C.TS;  AutoFarmLabel.TextColor3 = C.TS
		SkillsStroke.Color   = C.AC;  SkillsIcon.TextColor3   = C.AC;  SkillsLabel.TextColor3   = C.AC
		if _MOB_DROP_OPEN  then
			_MOB_DROP_OPEN = false
			CloseSidePanel(MobDropdown)
			SetExpandIcon(MobExpandBtn, false, C.TS)
		end
		if _BOSS_DROP_OPEN then
			_BOSS_DROP_OPEN = false
			CloseSidePanel(BossDropdown)
			SetExpandIcon(BossExpandBtn, false, C.TS)
		end
	end
end

