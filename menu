local function EquipTool(toolName)
	local char = Player.Character
	if not char then return false end
	local humanoid = char:FindFirstChildOfClass("Humanoid")
	if not humanoid then return false end

	-- Já está equipada no char
	local alreadyOn = char:FindFirstChild(toolName)
	if alreadyOn and alreadyOn:IsA("Tool") then return true end

	-- Procura na backpack atual
	local bp = GetBackpack()
	if bp then
		local tool = bp:FindFirstChild(toolName)
		if tool and tool:IsA("Tool") then
			humanoid:EquipTool(tool)
			return true
		end
	end

	return false
end

local function UnequipTool(toolName)
	local char = Player.Character
	if not char then return false end
	local equippedTool = char:FindFirstChild(toolName)
	if equippedTool and equippedTool:IsA("Tool") then
		local bp = GetBackpack()
		if bp then
			equippedTool.Parent = bp
		end
		return true
	end
	return false
end

