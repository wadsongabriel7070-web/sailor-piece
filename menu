-- =====================================================
-- LOOP PRINCIPAL DE FARM - TELEPORT DE LONGA DISTÂNCIA
-- Agora teleporta a cada 0.3 segundos de QUALQUER lugar
-- =====================================================
task.spawn(function()
	while task.wait(0.3) do
		if _FARM and #_FARM_LIST > 0 then
			local currentMob = _FARM_LIST[_FARM_INDEX]
			if currentMob then
				local mob, root, hum = FindMobByName(currentMob.name)
				if mob and root and hum then
					_FARM_TARGET = currentMob.name
					_CURRENT_TARGET_ROOT = root
					_CURRENT_TARGET_MODEL = mob
					
					-- TELEPORT IMEDIATO de longa distância
					TeleportToTarget(root)
					
					if hum.Health <= 0 then
						_CURRENT_TARGET_ROOT = nil
						_CURRENT_TARGET_MODEL = nil
						if #_FARM_LIST == 1 and currentMob.isBoss then
							_FARM_TARGET = currentMob.name .. " (Respawning...)"
							task.wait(3)
						else
							_FARM_INDEX = _FARM_INDEX + 1
							if _FARM_INDEX > #_FARM_LIST then _FARM_INDEX = 1 end
						end
					end
				else
					_CURRENT_TARGET_ROOT = nil
					_CURRENT_TARGET_MODEL = nil
					if #_FARM_LIST == 1 and currentMob.isBoss then
						_FARM_TARGET = currentMob.name .. " (Waiting...)"
						task.wait(3)
					else
						_FARM_INDEX = _FARM_INDEX + 1
						if _FARM_INDEX > #_FARM_LIST then _FARM_INDEX = 1 end
					end
				end
			end
		else
			_FARM_TARGET = nil
			_CURRENT_TARGET_ROOT = nil
			_CURRENT_TARGET_MODEL = nil
		end
	end
end)

