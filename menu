local function TeleportToTarget(target)
	local char = Player.Character
	if not char then return false end
	local hrp = char:FindFirstChild("HumanoidRootPart")
	if not hrp or not target then return false end
	local behindPos    = target.Position + target.CFrame.LookVector * -5
	local targetCFrame = CFrame.new(behindPos, target.Position)
	hrp.CFrame                  = targetCFrame
	hrp.AssemblyLinearVelocity  = Vector3.new(0, 0, 0)
	hrp.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
	_FARM_POSITION = targetCFrame
	if _BODY_GYRO then _BODY_GYRO.CFrame = targetCFrame end
	return true
end

-- =====================================================
-- AUTO ATTACK
-- =====================================================
local function CacheAttackRemotes()
	if #_ATTACK_REMOTES > 0 then return end
	pcall(function()
		for _, v in pairs(ReplicatedStorage:GetDescendants()) do
			if v:IsA("RemoteEvent") then
				local n = v.Name:lower()
				if n:find("punch") or n:find("attack") or n:find("hit") or n:find("damage")
				or n:find("combat") or n:find("strike") or n:find("swing") or n:find("slash") or n:find("fire") then
					table.insert(_ATTACK_REMOTES, v)
				end
			end
		end
	end)
end

local function SimulateClick()
	local now = tick()
	if now - _LAST_CLICK_TIME < _CLICK_DELAY then return end
	_LAST_CLICK_TIME = now
	if #_ATTACK_REMOTES > 0 then
		for _, r in ipairs(_ATTACK_REMOTES) do pcall(function() r:FireServer() end) end
	else
		CacheAttackRemotes()
	end
end

-- =====================================================
-- KEY PRESS SIMULATION
-- Tenta VirtualInputManager primeiro; fallback FireServer
-- =====================================================
local function PressKey(keyEnum)
	pcall(function()
		VirtualInputManager:SendKeyEvent(true,  keyEnum, false, game)
		task.wait(0.08)
		VirtualInputManager:SendKeyEvent(false, keyEnum, false, game)
	end)
end

-- =====================================================
-- START / STOP KEY LOOP
-- =====================================================
local function StartKeyLoop(keyStr, keyEnum)
	if _KEY_LOOPS[keyStr] then return end
	local alive = true
	_KEY_LOOPS[keyStr] = alive
	task.spawn(function()
		while _KEY_TOGGLES[keyStr] do
			PressKey(keyEnum)
			local elapsed = 0
			while elapsed < KEY_INTERVAL and _KEY_TOGGLES[keyStr] do
				task.wait(0.1)
				elapsed = elapsed + 0.1
			end
		end
		_KEY_LOOPS[keyStr] = nil
	end)
end

local function StopKeyLoop(keyStr)
	_KEY_TOGGLES[keyStr] = false
	-- loop vai parar naturalmente na próxima iteração
end

-- =====================================================
-- FIND MOB
-- =====================================================
local function FindMobByName(name)
	for _, obj in pairs(workspace:GetChildren()) do
		if obj:IsA("Model") and obj.Name == name then
			local hum = obj:FindFirstChildOfClass("Humanoid")
			if hum and hum.Health > 0 then local r = FindR(obj); if r then return obj, r, hum end end
		end
	end
	for _, obj in pairs(workspace:GetDescendants()) do
		if obj:IsA("Model") and obj.Name == name then
			local hum = obj:FindFirstChildOfClass("Humanoid")
			if hum and hum.Health > 0 then local r = FindR(obj); if r then return obj, r, hum end end
		end
	end
	local c = workspace:FindFirstChild("TimedBossSpawn_" .. name .. "_Container")
	if c then
		local bm = c:FindFirstChild("TimedBossSpawn_" .. name)
		if bm and bm:IsA("Model") then
			local hum = bm:FindFirstChildOfClass("Humanoid")
			if hum and hum.Health > 0 then local r = FindR(bm); if r then return bm, r, hum end end
		end
	end
	if name:find("Boss") then
		local base = name:gsub("Boss", "")
		local ac = workspace:FindFirstChild("TimedBossSpawn_" .. base .. "_Container")
		if ac then
			local bm = ac:FindFirstChild("TimedBossSpawn_" .. name)
			if bm and bm:IsA("Model") then
				local hum = bm:FindFirstChildOfClass("Humanoid")
				if hum and hum.Health > 0 then local r = FindR(bm); if r then return bm, r, hum end end
			end
		end
	end
	return nil, nil, nil
end

-- =====================================================
-- SKILLS
-- =====================================================
local function EquipTool(toolName)
	local char = Player.Character; if not char then return false end
	local hum = char:FindFirstChildOfClass("Humanoid"); if not hum then return false end
	if char:FindFirstChild(toolName) then return true end
	local bp = GetBackpack()
	if bp then
		local t = bp:FindFirstChild(toolName)
		if t and t:IsA("Tool") then hum:EquipTool(t); return true end
	end
	return false
end

local function UnequipTool(toolName)
	local char = Player.Character; if not char then return false end
	local et = char:FindFirstChild(toolName)
	if et and et:IsA("Tool") then
		local bp = GetBackpack(); if bp then et.Parent = bp end; return true
	end
	return false
end

