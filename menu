							TeleportToTarget(root)
						end
						if hum.Health <= 0 then
							if not _BOSS_FARM then _CURRENT_TARGET_ROOT = nil; _CURRENT_TARGET_MODEL = nil end
							_FARM_INDEX, _FARM_SUBINDEX = AdvanceIndex(_FARM_LIST, _FARM_INDEX, _FARM_SUBINDEX, #cg.variants)
						end
					else
						_FARM_TARGET = cg.displayName .. " (Searching...)"
						_FARM_INDEX, _FARM_SUBINDEX = AdvanceIndex(_FARM_LIST, _FARM_INDEX, _FARM_SUBINDEX, #cg.variants)
					end
				else
					_FARM_SUBINDEX = 1
				end
			end
		end
	end
end)

-- =====================================================
-- LOOP BOSS FARM
-- =====================================================
task.spawn(function()
	while task.wait(0.3) do
		if _BOSS_FARM and #_BOSS_LIST > 0 then
			local cg = _BOSS_LIST[_BOSS_INDEX]
			if cg then
				local variant = cg.variants[_BOSS_SUBINDEX]
				if variant then
					local mob, root, hum = FindMobByName(variant)
					if mob and root and hum then
						_BOSS_TARGET          = cg.displayName .. " [" .. variant .. "]"
						_CURRENT_TARGET_ROOT  = root
						_CURRENT_TARGET_MODEL = mob
						TeleportToTarget(root)
						if hum.Health <= 0 then
							_CURRENT_TARGET_ROOT = nil; _CURRENT_TARGET_MODEL = nil
							if #cg.variants == 1 then
								_BOSS_TARGET = cg.displayName .. " (Respawning...)"
								task.wait(3)
							else
								_BOSS_INDEX, _BOSS_SUBINDEX = AdvanceIndex(_BOSS_LIST, _BOSS_INDEX, _BOSS_SUBINDEX, #cg.variants)
							end
						end
					else
						if #cg.variants == 1 then
							_BOSS_TARGET = cg.displayName .. " (Waiting...)"
							task.wait(3)
						else
							_BOSS_INDEX, _BOSS_SUBINDEX = AdvanceIndex(_BOSS_LIST, _BOSS_INDEX, _BOSS_SUBINDEX, #cg.variants)
						end
					end
				else
					_BOSS_SUBINDEX = 1
				end
			end
		elseif _BOSS_FARM and #_BOSS_LIST == 0 then
			_BOSS_TARGET = nil
		end
	end
end)

