-- Anti-Push System
local function EnableAntiPush(char)
	if not char then return end
	local hrp = char:FindFirstChild("HumanoidRootPart")
	if not hrp then return end

	if _BODY_VELOCITY then pcall(function() _BODY_VELOCITY:Destroy() end) end
	if _BODY_GYRO then pcall(function() _BODY_GYRO:Destroy() end) end

	_BODY_VELOCITY = Instance.new("BodyVelocity")
	_BODY_VELOCITY.Name = RandomString(10)
	_BODY_VELOCITY.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
	_BODY_VELOCITY.Velocity = Vector3.new(0, 0, 0)
	_BODY_VELOCITY.Parent = hrp

	_BODY_GYRO = Instance.new("BodyGyro")
	_BODY_GYRO.Name = RandomString(10)
	_BODY_GYRO.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
	_BODY_GYRO.P = 10000
	_BODY_GYRO.D = 500
	_BODY_GYRO.Parent = hrp

	_ANTI_PUSH_ACTIVE = true
end

local function DisableAntiPush()
	if _BODY_VELOCITY then pcall(function() _BODY_VELOCITY:Destroy() end); _BODY_VELOCITY = nil end
	if _BODY_GYRO then pcall(function() _BODY_GYRO:Destroy() end); _BODY_GYRO = nil end
	_ANTI_PUSH_ACTIVE = false
	_FARM_POSITION = nil
end

-- =====================================================
-- TELEPORT DE LONGA DISTÂNCIA - CORRIGIDO
-- Agora teleporta de QUALQUER distância, não importa onde o player esteja
-- =====================================================
local function TeleportToTarget(target)
	local char = Player.Character
	if not char then return false end
	local hrp = char:FindFirstChild("HumanoidRootPart")
	if not hrp or not target then return false end

	-- Calcula posição atrás do alvo
	local offset = target.CFrame.LookVector * -5
	local behindPos = target.Position + offset
	local targetCFrame = CFrame.new(behindPos, target.Position)
	
	-- TELEPORT FORÇADO - Remove qualquer física que possa interferir
	hrp.CFrame = targetCFrame
	hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
	hrp.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
	
	-- Atualiza posição de farm
	_FARM_POSITION = targetCFrame
	
	if _BODY_GYRO then 
		_BODY_GYRO.CFrame = targetCFrame 
	end
	
	return true
end

-- Auto Attack
local function CacheAttackRemotes()
	if #_ATTACK_REMOTES > 0 then return end
	pcall(function()
		for _, v in pairs(ReplicatedStorage:GetDescendants()) do
			if v:IsA("RemoteEvent") then
				local name = v.Name:lower()
				if name:find("punch") or name:find("attack") or name:find("hit") or
				   name:find("damage") or name:find("combat") or name:find("strike") or
				   name:find("swing") or name:find("slash") or name:find("fire") then
					table.insert(_ATTACK_REMOTES, v)
				end
			end
		end
	end)
end

local function SimulateClick()
	local currentTime = tick()
	if currentTime - _LAST_CLICK_TIME < _CLICK_DELAY then return end
	_LAST_CLICK_TIME = currentTime
	if #_ATTACK_REMOTES > 0 then
		for _, remote in ipairs(_ATTACK_REMOTES) do
			pcall(function() remote:FireServer() end)
		end
	else
		CacheAttackRemotes()
	end
end

-- =====================================================
-- SISTEMA DE BUSCA DE MOBS/BOSSES MELHORADO
-- Procura por nome direto E por containers de TimedBossSpawn
-- =====================================================
local function FindMobByName(name)
	-- Primeiro tenta encontrar diretamente no workspace
	for _, obj in pairs(workspace:GetChildren()) do
		if obj:IsA("Model") and obj.Name == name then
			local hum = obj:FindFirstChildOfClass("Humanoid")
			if hum and hum.Health > 0 then
				local root = FindR(obj)
				if root then return obj, root, hum end
			end
		end
	end
	
	-- Busca em todos os descendentes
	for _, obj in pairs(workspace:GetDescendants()) do
		if obj:IsA("Model") and obj.Name == name then
			local hum = obj:FindFirstChildOfClass("Humanoid")
			if hum and hum.Health > 0 then
				local root = FindR(obj)
				if root then return obj, root, hum end
			end
		end
	end
	
	-- Busca específica para TimedBossSpawn containers
	local containerName = "TimedBossSpawn_" .. name .. "_Container"
	local container = workspace:FindFirstChild(containerName)
	if container then
		local bossModel = container:FindFirstChild("TimedBossSpawn_" .. name)
		if bossModel and bossModel:IsA("Model") then
			local hum = bossModel:FindFirstChildOfClass("Humanoid")
			if hum and hum.Health > 0 then
				local root = FindR(bossModel)
				if root then return bossModel, root, hum end
			end
		end
	end
	
	-- Busca alternativa para bosses sem "Boss" no nome do container
	-- Ex: TimedBossSpawn_Yamato_Container para YamatoBoss
	if name:find("Boss") then
		local baseName = name:gsub("Boss", "")
		local altContainerName = "TimedBossSpawn_" .. baseName .. "_Container"
		local altContainer = workspace:FindFirstChild(altContainerName)
		if altContainer then
			local bossModel = altContainer:FindFirstChild("TimedBossSpawn_" .. name)
			if bossModel and bossModel:IsA("Model") then
				local hum = bossModel:FindFirstChildOfClass("Humanoid")
				if hum and hum.Health > 0 then
					local root = FindR(bossModel)
					if root then return bossModel, root, hum end
				end
			end
		end
	end
	
	return nil, nil, nil
end

