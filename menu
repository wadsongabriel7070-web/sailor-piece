-- =====================================================
-- LOOP DE COMBATE - Ataque e animações
-- =====================================================
RunService:BindToRenderStep(loop_name, loop_priority, function()
	if _FARM and _CURRENT_TARGET_ROOT then
		if _CURRENT_TARGET_ROOT:IsDescendantOf(workspace) then
			-- Auto attack
			if _AUTO_ATTACK_ACTIVE then 
				SimulateClick() 
			end
			
			-- Para animações
			local lc = Player.Character
			if lc then
				local hum = lc:FindFirstChildOfClass("Humanoid")
				if hum then
					local animator = hum:FindFirstChildOfClass("Animator")
					if animator then
						for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
							if track.IsPlaying then track:Stop() end
						end
					end
				end
			end
		end
	end

	-- Auto-equip: só tenta se não está equipada E está na backpack
	for toolName, _ in pairs(_EQUIPPED_SKILLS) do
		local char = Player.Character
		if char then
			local hum = char:FindFirstChildOfClass("Humanoid")
			if hum and not char:FindFirstChild(toolName) then
				local bp = GetBackpack()
				if bp and bp:FindFirstChild(toolName) then
					EquipTool(toolName)
				end
			end
		end
	end
end)

