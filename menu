local function PositionSidePanel(panel, anchorBtn)
	local mfPos  = MF.AbsolutePosition
	local mfSize = MF.AbsoluteSize
	local x      = mfPos.X + mfSize.X + SIDE_GAP
	local btnY   = anchorBtn.AbsolutePosition.Y
	local sh     = workspace.CurrentCamera.ViewportSize.Y
	local sw     = workspace.CurrentCamera.ViewportSize.X

	if x + SIDE_W > sw - 4 then x = mfPos.X - SIDE_W - SIDE_GAP end
	if x < 4 then x = 4 end

	local y = btnY
	if y + SIDE_MAX_H > sh - 4 then y = sh - SIDE_MAX_H - 4 end
	if y < 4 then y = 4 end

	panel.Position = UDim2.new(0, x, 0, y)
end

local function PopulateSidePanel(scroll, layout, groups, selectedTable, groupsList, isBoss)
	for _, ch in ipairs(scroll:GetChildren()) do
		if ch:IsA("Frame") or ch:IsA("TextButton") then ch:Destroy() end
	end

	local accentColor = isBoss and C.BOSS or C.ON

	for _, groupData in ipairs(groups) do
		local row = Instance.new("TextButton")
		row.Size             = UDim2.new(1, -6, 0, SIDE_ITEM_H)
		row.BackgroundColor3 = Color3.fromRGB(30, 30, 46)
		row.BorderSizePixel  = 0
		row.Text             = ""
		row.ZIndex           = 22
		row.Parent           = scroll
		Instance.new("UICorner", row).CornerRadius = UDim.new(0, 6)

		local rowStroke = Instance.new("UIStroke")
		rowStroke.Color     = selectedTable[groupData.displayName] and accentColor or C.BR
		rowStroke.Thickness = 1
		rowStroke.ZIndex    = 22
		rowStroke.Parent    = row

		local countSuffix = (#groupData.variants > 1) and (" x" .. #groupData.variants) or ""
		local nameLbl = Instance.new("TextLabel")
		nameLbl.Size                 = UDim2.new(1, -30, 1, 0)
		nameLbl.Position             = UDim2.new(0, 6, 0, 0)
		nameLbl.BackgroundTransparency = 1
		nameLbl.Text                 = groupData.displayName .. countSuffix
		nameLbl.TextColor3           = C.TP
		nameLbl.TextSize             = 10
		nameLbl.Font                 = Enum.Font.Gotham
		nameLbl.TextXAlignment       = Enum.TextXAlignment.Left
		nameLbl.ZIndex               = 23
		nameLbl.Parent               = row

		local chk = Instance.new("Frame")
		chk.Size             = UDim2.new(0, 14, 0, 14)
		chk.Position         = UDim2.new(1, -18, 0.5, -7)
		chk.BackgroundColor3 = selectedTable[groupData.displayName] and accentColor or C.OFF
		chk.BorderSizePixel  = 0
		chk.ZIndex           = 23
		chk.Parent           = row
		Instance.new("UICorner", chk).CornerRadius = UDim.new(0, 3)

		local chkMark = Instance.new("TextLabel")
		chkMark.Size                 = UDim2.new(1, 0, 1, 0)
		chkMark.BackgroundTransparency = 1
		chkMark.Text                 = "\u{2713}"
		chkMark.TextColor3           = C.TP
		chkMark.TextSize             = 10
		chkMark.Font                 = Enum.Font.GothamBold
		chkMark.Visible              = selectedTable[groupData.displayName] ~= nil
		chkMark.ZIndex               = 24
		chkMark.Parent               = chk

		row.MouseButton1Click:Connect(function()
			if selectedTable[groupData.displayName] then
				selectedTable[groupData.displayName] = nil
				chk.BackgroundColor3 = C.OFF
				chkMark.Visible      = false
				rowStroke.Color      = C.BR
			else
				selectedTable[groupData.displayName] = true
				chk.BackgroundColor3 = accentColor
				chkMark.Visible      = true
				rowStroke.Color      = accentColor
			end
			if isBoss then
				_BOSS_LIST = {}
				for _, g in ipairs(groupsList) do
					if selectedTable[g.displayName] then table.insert(_BOSS_LIST, g) end
				end
				_BOSS_INDEX = 1; _BOSS_SUBINDEX = 1
			else
				_FARM_LIST = {}
				for _, g in ipairs(groupsList) do
					if selectedTable[g.displayName] then table.insert(_FARM_LIST, g) end
				end
				_FARM_INDEX = 1; _FARM_SUBINDEX = 1
			end
		end)
	end

	task.spawn(function()
		task.wait(0.05)
		scroll.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 8)
	end)
end

local function OpenSidePanel(panel, scroll, layout, groups, selectedTable, groupsList, isBoss, anchorBtn)
	PopulateSidePanel(scroll, layout, groups, selectedTable, groupsList, isBoss)
	PositionSidePanel(panel, anchorBtn)

	panel.Size    = UDim2.new(0, SIDE_W, 0, 0)
	panel.Visible = true

	task.spawn(function()
		task.wait(0.06)
		local totalH = math.min(layout.AbsoluteContentSize.Y + 36, SIDE_MAX_H)
		TweenService:Create(panel, TW, {Size = UDim2.new(0, SIDE_W, 0, totalH)}):Play()
	end)

	TweenService:Create(panel, TW, {Size = UDim2.new(0, SIDE_W, 0, SIDE_MAX_H)}):Play()
end

local function CloseSidePanel(panel)
	TweenService:Create(panel, TW, {Size = UDim2.new(0, SIDE_W, 0, 0)}):Play()
	task.delay(0.2, function() panel.Visible = false end)
end

