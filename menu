local function UpdateSkillsList()
	local allTools = {}
	local bp = GetBackpack()
	if bp then
		for _, tool in pairs(bp:GetChildren()) do
			if tool:IsA("Tool") then table.insert(allTools, tool.Name) end
		end
	end
	if Player.Character then
		for _, tool in pairs(Player.Character:GetChildren()) do
			if tool:IsA("Tool") then
				local found = false
				for _, n in ipairs(allTools) do if n == tool.Name then found = true break end end
				if not found then table.insert(allTools, tool.Name) end
			end
		end
	end
	for index, toolName in ipairs(allTools) do
		if not _SKILL_BUTTONS[toolName] then CreateSkillButton(toolName, index) end
	end
	task.wait(0.1)
	SkillsScroll.CanvasSize = UDim2.new(0, 0, 0, SkillsLayout.AbsoluteContentSize.Y + 10)
end

