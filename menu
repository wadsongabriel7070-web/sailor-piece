-- ADVANCE INDEX
-- =====================================================
local function AdvanceIndex(list, index, subindex, groupCount)
	subindex = subindex + 1
	if subindex > groupCount then
		subindex = 1
		index = index + 1
		if index > #list then index = 1 end
	end
	return index, subindex
end

